      }
      .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .footer-links a {
        color: rgba(255, 255, 255, 0.65);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s;
      }
      .footer-links a:hover {
