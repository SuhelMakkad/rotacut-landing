      /* RESPONSIVE */
      @media (max-width: 1024px) {
        .hero-inner {
          grid-template-columns: 1fr;
        }
        .hero-right {
          display: none;
        }
        .products-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .dealer-grid {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
        .footer-top {
          grid-template-columns: 1fr 1fr;
        }
      }
      @media (max-width: 768px) {
        nav {
          padding: 0 1.5rem;
        }
        .nav-links,
        .nav-actions {
          display: none;
        }
        .hamburger {
