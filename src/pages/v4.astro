---
import "../styles/global.css";
import Building2 from "@lucide/astro/icons/building-2";
import TrainFront from "@lucide/astro/icons/train-front";
import Anchor from "@lucide/astro/icons/anchor";
import Zap from "@lucide/astro/icons/zap";
import Fuel from "@lucide/astro/icons/fuel";
import Pickaxe from "@lucide/astro/icons/pickaxe";
import Cog from "@lucide/astro/icons/cog";
import Plane from "@lucide/astro/icons/plane";
import Gem from "@lucide/astro/icons/gem";
import PencilRuler from "@lucide/astro/icons/pencil-ruler";
import Target from "@lucide/astro/icons/target";
import Wind from "@lucide/astro/icons/wind";
import Shield from "@lucide/astro/icons/shield";
import Ruler from "@lucide/astro/icons/ruler";

const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rotacut — Precision Annular Cutters</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Nunito+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      :root {
        --green: #1b5e20;
        --green2: #2e7d32;
        --green3: #388e3c;
        --green-pale: #e8f5e9;
        --green-mid: #c8e6c9;
        --orange: #f57c00;
        --orange-pale: #fff3e0;
        --white: #ffffff;
        --off: #f7f9f7;
        --text: #1a2b1a;
        --muted: #5d7a5d;
        --border: #d4e4d4;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--white);
        color: var(--text);
        font-family: "Nunito Sans", sans-serif;
        font-weight: 400;
        overflow-x: hidden;
      }

      /* NAV */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        padding: 0 2.5rem;
        height: 68px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-logo-wrap {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .nav-logo-icon {
        width: 36px;
        height: 36px;
        background: var(--green);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Syne", sans-serif;
        font-weight: 800;
        font-size: 0.875rem;
        color: #fff;
        letter-spacing: 0.05em;
      }
      .nav-logo-text {
        font-family: "Syne", sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .nav-logo-text span {
        color: var(--orange);
      }
      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .nav-links a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--text);
      }
      .nav-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }
      .nav-cta-ghost {
        border: 1.5px solid var(--border);
        color: var(--text);
        padding: 0.45rem 1.25rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        border-radius: 8px;
        transition: border-color 0.2s;
        font-family: "Syne", sans-serif;
      }
      .nav-cta-ghost:hover {
        border-color: var(--green);
        color: var(--green);
      }
      .nav-cta {
        background: var(--orange);
        color: #fff;
        padding: 0.5rem 1.25rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        border-radius: 8px;
        transition:
          background 0.2s,
          transform 0.15s;
        font-family: "Syne", sans-serif;
      }
      .nav-cta:hover {
        background: #e65100;
        transform: translateY(-1px);
      }
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--text);
        border-radius: 1px;
      }
      .mobile-menu {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--white);
        z-index: 99;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2rem;
      }
      .mobile-menu.open {
        display: flex;
      }
      .mobile-menu a {
        color: var(--text);
        text-decoration: none;
        font-family: "Syne", sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
      }
      .mobile-close {
        position: absolute;
        top: 1.5rem;
        right: 2.5rem;
        color: var(--text);
        cursor: pointer;
        background: none;
        border: none;
        font-size: 1.5rem;
      }

      /* HERO */
      .hero {
        padding-top: 68px;
        min-height: 100vh;
        background: var(--green);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
      }
      /* Gradient mesh background */
      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 80% at 90% 20%, rgba(46, 125, 50, 0.8) 0%, transparent 60%),
          radial-gradient(ellipse 60% 60% at 10% 80%, rgba(27, 94, 32, 0.9) 0%, transparent 50%),
          radial-gradient(ellipse 100% 50% at 50% 100%, rgba(56, 142, 60, 0.4) 0%, transparent 60%);
        pointer-events: none;
      }
      /* Decorative circle */
      .hero::after {
        content: "";
        position: absolute;
        right: -15%;
        top: 50%;
        transform: translateY(-50%);
        width: 700px;
        height: 700px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .hero-inner {
        position: relative;
        z-index: 2;
        max-width: 1200px;
        margin: 0 auto;
        padding: 5rem 2.5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        width: 100%;
      }
      .hero-left {
      }
      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 100px;
        padding: 0.35rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 2rem;
        backdrop-filter: blur(8px);
      }
      .hero-badge::before {
        content: "●";
        color: #a5d6a7;
        font-size: 0.5rem;
      }
      .hero-headline {
        font-family: "Syne", sans-serif;
        font-size: clamp(2.8rem, 5.5vw, 4.5rem);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: #fff;
        margin: 0 0 1.5rem;
      }
      .hero-headline span {
        color: #a5d6a7;
      }
      .hero-sub {
        font-size: 1.05rem;
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.75;
        max-width: 440px;
        margin-bottom: 2.5rem;
        font-weight: 300;
      }
      .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }
      .btn-hero-primary {
        background: var(--orange);
        color: #fff;
        padding: 0.875rem 2rem;
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        border-radius: 10px;
        font-family: "Syne", sans-serif;
        transition:
          background 0.2s,
          transform 0.15s,
          box-shadow 0.2s;
        box-shadow: 0 4px 16px rgba(245, 124, 0, 0.3);
      }
      .btn-hero-primary:hover {
        background: #e65100;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(245, 124, 0, 0.4);
      }
      .btn-hero-secondary {
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: #fff;
        padding: 0.875rem 2rem;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 10px;
        font-family: "Syne", sans-serif;
        backdrop-filter: blur(8px);
        transition: background 0.2s;
      }
      .btn-hero-secondary:hover {
        background: rgba(255, 255, 255, 0.2);
      }
      .hero-trust {
        display: flex;
        gap: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
      }
      .trust-item {
      }
      .trust-num {
        font-family: "Syne", sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
      }
      .trust-num span {
        color: #a5d6a7;
      }
      .trust-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 500;
        margin-top: 0.1rem;
      }
      .hero-right {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }
      .hero-img-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: 3rem 2.5rem;
        position: relative;
      }
      .hero-img-card img {
        width: 100%;
        max-width: 380px;
        filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.3));
      }
      .hero-float-badge {
        position: absolute;
        background: #fff;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .hero-float-badge.top-right {
        top: -12px;
        right: -12px;
      }
      .hero-float-badge.bottom-left {
        bottom: -12px;
        left: -12px;
      }
      .badge-icon {
        font-size: 1.2rem;
      }
      .badge-text {
      }
      .badge-title {
        font-family: "Syne", sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--text);
      }
      .badge-sub {
        font-size: 0.65rem;
        color: var(--muted);
      }

      /* LAYOUT */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }
      section {
        padding: 7rem 0;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--green-pale);
        color: var(--green);
        border: 1px solid var(--green-mid);
        border-radius: 100px;
        padding: 0.3rem 0.875rem;
        font-size: 0.7rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .chip::before {
        content: "●";
        font-size: 0.45rem;
      }
      .sec-title {
        font-family: "Syne", sans-serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
        margin: 0 0 1rem;
        line-height: 1.1;
      }
      .sec-title span {
        color: var(--green);
      }
      .sec-sub {
        font-size: 1rem;
        color: var(--muted);
        line-height: 1.75;
        max-width: 500px;
        margin-bottom: 3.5rem;
        font-weight: 400;
      }

      /* PRODUCTS */
      #products {
        background: var(--off);
      }
      .products-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
      }
      .prod-card {
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        padding: 1.75rem 1.5rem;
        transition:
          box-shadow 0.25s,
          transform 0.25s,
          border-color 0.25s;
      }
      .prod-card:hover {
        box-shadow: 0 12px 40px rgba(27, 94, 32, 0.12);
        transform: translateY(-4px);
        border-color: var(--green-mid);
      }
      .prod-img-wrap {
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
      }
      .prod-img {
        max-height: 140px;
        width: auto;
        object-fit: contain;
        transition: transform 0.3s;
        filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.08));
      }
      .prod-card:hover .prod-img {
        transform: scale(1.06) translateY(-4px);
      }
      .prod-tag-chip {
        display: inline-block;
        background: var(--green-pale);
        color: var(--green);
        border-radius: 100px;
        padding: 0.2rem 0.65rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        margin-bottom: 0.6rem;
      }
      .prod-name {
        font-family: "Syne", sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text);
        margin: 0 0 0.6rem;
        letter-spacing: -0.01em;
      }
      .prod-desc {
        font-size: 0.825rem;
        color: var(--muted);
        line-height: 1.65;
        margin-bottom: 1.25rem;
      }
      .prod-specs {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
      }
      .spec-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .sk {
        font-size: 0.75rem;
        color: var(--muted);
      }
      .sv {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text);
        font-family: "Syne", sans-serif;
      }
      .prod-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--green);
        text-decoration: none;
        margin-top: 1.25rem;
        font-family: "Syne", sans-serif;
        transition: gap 0.2s;
      }
      .prod-cta:hover {
        gap: 0.7rem;
      }

      /* USP */
      #why {
        background: var(--white);
      }
      .usp-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      .usp-card {
        background: var(--off);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        padding: 2rem 1.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        justify-content: center;
        transition:
          box-shadow 0.2s,
          border-color 0.2s;
      }
      .usp-card:hover {
        box-shadow: 0 8px 28px rgba(27, 94, 32, 0.08);
        border-color: var(--green-mid);
      }
      .usp-icon-wrap {
        width: 48px;
        height: 48px;
        background: var(--green-pale);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1.25rem;
        border: 1px solid var(--green-mid);
      }
      .usp-title {
        font-family: "Syne", sans-serif;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 0.6rem;
        letter-spacing: -0.01em;
      }
      .usp-text {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.7;
      }

      /* MATERIALS */
      #materials {
        background: var(--green);
        color: #fff;
      }
      .mat-legend {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
      }
      .mat-legend-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.7);
      }
      .mat-dot-opt {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #a5d6a7;
      }
      .mat-dot-good {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--orange);
      }
      .mat-dot-pos {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
      }
      .mat-table {
        width: 100%;
        border-collapse: collapse;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        overflow: hidden;
      }
      .mat-table th {
        padding: 1rem 1.5rem;
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 700;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
        font-family: "Syne", sans-serif;
      }
      .mat-table th:not(:first-child) {
        text-align: center;
      }
      .mat-table td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.85);
      }
      .mat-table td:not(:first-child) {
        text-align: center;
      }
      .mat-table tr:last-child td {
        border-bottom: none;
      }
      .mat-table tr:hover td {
        background: rgba(255, 255, 255, 0.04);
      }
      .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
      }
      .pill-opt {
        background: rgba(165, 214, 167, 0.2);
      }
      .pill-opt::after {
        content: "●";
        color: #a5d6a7;
        font-size: 0.75rem;
      }
      .pill-good {
        background: rgba(245, 124, 0, 0.2);
      }
      .pill-good::after {
        content: "◑";
        color: var(--orange);
        font-size: 0.75rem;
      }
      .pill-pos {
        background: rgba(255, 255, 255, 0.07);
      }
      .pill-pos::after {
        content: "○";
        color: rgba(255, 255, 255, 0.35);
        font-size: 0.75rem;
      }
      .pill-none::after {
        content: "—";
        color: rgba(255, 255, 255, 0.15);
        font-size: 0.75rem;
      }
      #materials .chip {
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.8);
        border-color: rgba(255, 255, 255, 0.2);
      }
      #materials .sec-title {
        color: #fff;
      }
      #materials .sec-title span {
        color: #a5d6a7;
      }
      #materials .sec-sub {
        color: rgba(255, 255, 255, 0.65);
      }

      /* INDUSTRIES */
      #industries {
        background: var(--off);
      }
      .industries-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      .ind-card {
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 1.75rem 1.25rem;
        text-align: center;
        transition:
          box-shadow 0.2s,
          border-color 0.2s,
          transform 0.2s;
      }
      .ind-card:hover {
        box-shadow: 0 6px 20px rgba(27, 94, 32, 0.1);
        border-color: var(--green-mid);
        transform: translateY(-3px);
      }
      .ind-icon {
        font-size: 2.25rem;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .ind-name {
        font-family: "Syne", sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text);
      }

      /* STATS */
      .stats-section {
        background: var(--white);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 4rem 0;
      }
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }
      .stat-cell {
        text-align: center;
        padding: 1rem;
        border-right: 1px solid var(--border);
        position: relative;
      }
      .stat-cell:last-child {
        border: none;
      }
      .stat-num {
        font-family: "Syne", sans-serif;
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--green);
        letter-spacing: -0.02em;
        line-height: 1;
      }
      .stat-num span {
        color: var(--orange);
      }
      .stat-label {
        font-size: 0.75rem;
        color: var(--muted);
        font-weight: 600;
        margin-top: 0.4rem;
      }

      /* DEALER */
      #dealer {
        background: var(--off);
      }
      .dealer-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
      }
      .dealer-card {
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: 20px;
        padding: 2.5rem;
      }
      .dealer-card h3 {
